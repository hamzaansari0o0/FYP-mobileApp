{
  "expo": {
    "name": "CourtChuno",
    "slug": "courtchuno",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/courtchuno-logo.png",
    "scheme": "courtchuno",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.courtchuno.app"
    },
    "android": {
      "package": "com.courtchuno.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/courtchuno-logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/images/courtchuno-logo.png",
          "color": "#ffffff"
        }
      ],
      "expo-router",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "acba9aa0-4b6c-4f2c-bca0-f1acf14c89dd"
      },
      "router": {}
    }
  }
}
